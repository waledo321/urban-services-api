{
  "info": {
    "name": "Urban Services API",
    "description": "REST API collection for Smart Urban Services Management Platform backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Unified response has envelope keys', function () {",
          "    const jsonData = pm.response.json();",
          "    pm.expect(jsonData).to.have.property('success');",
          "    pm.expect(jsonData).to.have.property('message');",
          "    pm.expect(jsonData).to.have.property('data');",
          "    pm.expect(jsonData).to.have.property('errors');",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tester@example.com\",\n  \"password\": \"password\",\n  \"device_name\": \"flutter-app\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data.token) {",
                  "  pm.environment.set('token', jsonData.data.token);",
                  "}",
                  "pm.test('Login is successful', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(jsonData.success).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Buildings",
      "item": [
        {"name":"List Buildings","request":{"method":"GET","url":{"raw":"{{baseUrl}}/api/v1/buildings","host":["{{baseUrl}}"],"path":["api","v1","buildings"]}}},
        {"name":"Create Building","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"name\": \"Al Noor Building\",\n  \"real_estate_number\": \"RE-1001\",\n  \"license_number\": \"LIC-2026-01\",\n  \"total_floors\": 5,\n  \"has_basement\": true,\n  \"has_garage\": true,\n  \"ownership_type\": \"private\",\n  \"is_illegal\": false,\n  \"coordinates\": {\n    \"lat\": 33.3152,\n    \"lng\": 44.3661\n  }\n}"},"url":{"raw":"{{baseUrl}}/api/v1/buildings","host":["{{baseUrl}}"],"path":["api","v1","buildings"]}}},
        {"name":"Show Building","request":{"method":"GET","url":{"raw":"{{baseUrl}}/api/v1/buildings/{{buildingId}}","host":["{{baseUrl}}"],"path":["api","v1","buildings","{{buildingId}}"]}}},
        {"name":"Update Building","request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"name\": \"Al Noor Building Updated\",\n  \"total_floors\": 6\n}"},"url":{"raw":"{{baseUrl}}/api/v1/buildings/{{buildingId}}","host":["{{baseUrl}}"],"path":["api","v1","buildings","{{buildingId}}"]}}},
        {"name":"Delete Building","request":{"method":"DELETE","url":{"raw":"{{baseUrl}}/api/v1/buildings/{{buildingId}}","host":["{{baseUrl}}"],"path":["api","v1","buildings","{{buildingId}}"]}}}
      ]
    },
    {
