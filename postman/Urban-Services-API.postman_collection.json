        {"name":"Delete Apartment","request":{"method":"DELETE","url":{"raw":"{{baseUrl}}/api/v1/apartments/{{apartmentId}}","host":["{{baseUrl}}"],"path":["api","v1","apartments","{{apartmentId}}"]}}}
