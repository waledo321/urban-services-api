        {"name":"Create Apartment","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"building_id\": {{buildingId}},\n  \"floor_type\": \"residential\",\n  \"water_meter\": \"WM-001\",\n  \"electricity_meter\": \"EM-001\",\n  \"landline\": \"123456789\",\n  \"is_sealed\": false\n}"},"url":{"raw":"{{baseUrl}}/api/v1/apartments","host":["{{baseUrl}}"],"path":["api","v1","apartments"]}}},
        {"name":"Show Apartment","request":{"method":"GET","url":{"raw":"{{baseUrl}}/api/v1/apartments/{{apartmentId}}","host":["{{baseUrl}}"],"path":["api","v1","apartments","{{apartmentId}}"]}}},
