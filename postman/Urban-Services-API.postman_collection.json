        {"name":"Create Family","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"apartment_id\": {{apartmentId}},\n  \"family_book\": \"FB-1001\",\n  \"health_status\": \"good\",\n  \"living_status\": \"resident\",\n  \"last_aid_date\": \"2026-03-01\",\n  \"unemployed_count\": 1,\n  \"students_count\": 2,\n  \"occupancy_type\": \"owner\"\n}"},"url":{"raw":"{{baseUrl}}/api/v1/families","host":["{{baseUrl}}"],"path":["api","v1","families"]}}},
